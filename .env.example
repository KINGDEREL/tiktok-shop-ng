# TikTok Shop API Credentials
# Copy this file to .env.local and fill in your values

# TikTok Developer App Credentials
# Get these from https://partner.tiktokshop.com/
TIKTOK_CLIENT_ID=your_client_id_here
TIKTOK_CLIENT_SECRET=your_client_secret_here

# Callback URL for OAuth (must match TikTok app settings)
TIKTOK_CALLBACK_URL=https://tiktok-shop-ng.vercel.app/api/auth

# Your TikTok Shop credentials
TIKTOK_MERCHANT_ID=your_merchant_id_here
TIKTOK_SHOP_ID=your_shop_id_here

# Access tokens (obtained through OAuth flow)
# In production, store these securely (database, encrypted)
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=

# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Debug mode
VITE_DEBUG=false